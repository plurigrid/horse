\p{nanoclj-zig REPL usage:}
\pre{\startverb
;; Load session 5 CSV
(def data (brainfloj-read "session5_helek_entropy.csv" 12 0))
;; => {:samples 250 :channels 12 :entropy 0.795 :trit 0}

;; Or process raw EEG directly
(def raw (brainfloj-read "cognionics_session5_64ch.csv" 64 1))
;; => {:samples 418282 :channels 64 :entropy ... :trit ...}
\stopverb}
}

